# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit real values.
#
# When set, the demo app sends bug-report uploads to this base URL instead
# of the production tracebug.netlify.app. Used while developing the cloud
# portal locally — point it at your locally-running `website/` (port 3001).

NEXT_PUBLIC_TRACEBUG_CLOUD=http://localhost:3001
