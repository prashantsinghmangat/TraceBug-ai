# Copy this file to .env.local and fill in the values from your Supabase project.
# .env.local is gitignored — never commit real credentials.
#
# Get these from Supabase Dashboard → Settings → API:
#   - Project URL    → NEXT_PUBLIC_SUPABASE_URL
#   - anon (public)  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - service_role   → SUPABASE_SERVICE_ROLE_KEY  ⚠️  SECRET — server-side only

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public base URL of this Next.js site. Used in auth redirects, share links, OG tags.
# Local dev:  http://localhost:3001
# Production: https://tracebug.netlify.app
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ── AI Root-Cause (server-side Claude call) ──────────────────────────────────
# Get a key from https://console.anthropic.com  ⚠️  SECRET — server-side only.
# Without this set, /api/ai/diagnose returns 503 ai_disabled.
ANTHROPIC_API_KEY=sk-ant-...
# Model for diagnoses. Default claude-opus-4-8 (highest quality). Swap to
# claude-sonnet-4-6 to cut per-analysis cost (~$3/$15 vs $5/$25 per MTok).
TRACEBUG_AI_MODEL=claude-opus-4-8

# ── SDK iframe bridge origin allowlist ───────────────────────────────────────
# Comma-separated list of customer origins allowed to embed /sdk-bridge.
# REQUIRED in production — an empty list makes the bridge refuse all parents
# (fail-closed). localhost is allowed automatically in development.
# Example: https://app.customer.com,https://staging.customer.com
NEXT_PUBLIC_SDK_ALLOWED_ORIGINS=
