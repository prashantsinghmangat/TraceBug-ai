{
  "name": "tracebug-sdk",
  "version": "1.9.0",
  "description": "Capture a browser bug into one offline .html file your AI coding agent reads over MCP and fixes — session replay, console, network, repro timeline, and a generated failing test. Local-first, zero backend. Free.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./playwright": {
      "import": {
        "types": "./dist/playwright.d.ts",
        "default": "./dist/playwright.js"
      },
      "require": {
        "types": "./dist/playwright.d.cts",
        "default": "./dist/playwright.cjs"
      }
    }
  },
  "bin": {
    "tracebug": "dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "gen:rrweb": "node scripts/gen-rrweb-runtime.mjs",
    "prebuild": "npm run gen:rrweb",
    "build": "tsup",
    "build:all": "npm run gen:rrweb && tsup && node -e \"require('fs').copyFileSync('tracebug-extension/tracebug-sdk.js','website/public/tracebug-sdk.js')\" && echo [OK] npm package: dist/ && echo [OK] Chrome extension: tracebug-extension/tracebug-sdk.js && echo [OK] website sandbox SDK synced",
    "build:cli": "npm run gen:rrweb && tsup && node -e \"require('fs').copyFileSync('dist/bin.mjs','packages/tracebug/bin.mjs');console.log('[OK] CLI package: packages/tracebug/bin.mjs')\"",
    "build:example": "npm run gen:rrweb && tsup && cd example-app && npm install && echo [OK] Example app updated",
    "build:ext": "npm run gen:rrweb && tsup && node tracebug-extension/build/build-ext.mjs && node -e \"require('fs').copyFileSync('tracebug-extension/tracebug-sdk.js','website/public/tracebug-sdk.js')\"",
    "zip:ext": "npm run build:ext && node tracebug-extension/build/zip-ext.mjs",
    "ext:lint": "web-ext lint --source-dir tracebug-extension/dist/firefox --self-hosted",
    "ext:firefox": "web-ext run --source-dir tracebug-extension/dist/firefox",
    "dev": "npm run gen:rrweb && tsup --watch",
    "prepare": "npm run gen:rrweb && tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json",
    "lint": "eslint src/ cli/"
  },
  "keywords": [
    "bug-tracking",
    "bug-reporting",
    "error-reporting",
    "debugging",
    "debug",
    "devtools",
    "developer-tools",
    "session-replay",
    "session-recording",
    "root-cause-analysis",
    "qa-testing",
    "qa-tool",
    "chrome-extension",
    "browser-extension",
    "github-issues",
    "github",
    "jira",
    "bug-reproduction",
    "reproduction-steps",
    "sentry-alternative",
    "logrocket-alternative",
    "bugsnag-alternative",
    "fullstory-alternative",
    "console-errors",
    "network-errors",
    "frontend-debugging",
    "react",
    "nextjs",
    "vue",
    "angular",
    "typescript",
    "javascript"
  ],
  "author": {
    "name": "Prashant Singh Mangat",
    "url": "https://github.com/prashantsinghmangat"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prashantsinghmangat/TraceBug-ai.git"
  },
  "homepage": "https://tracebug.dev",
  "bugs": {
    "url": "https://github.com/prashantsinghmangat/TraceBug-ai/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "axe-core": "^4.11.4",
    "html2canvas": "1.4.1",
    "rrweb": "^2.1.0"
  }
}
