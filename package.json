{
  "name": "tracebug-sdk",
  "version": "1.3.0",
  "description": "Capture a bug, see the root cause, and create a GitHub issue in 5 seconds. Zero-backend, browser-only debugging assistant. Free Sentry/LogRocket alternative.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "tracebug": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:all": "tsup && echo [OK] npm package: dist/ && echo [OK] Chrome extension: tracebug-extension/tracebug-sdk.js",
    "build:example": "tsup && cd example-app && npm install && echo [OK] Example app updated",
    "dev": "tsup --watch",
    "prepare": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ cli/"
  },
  "keywords": [
    "bug-tracking",
    "bug-reporting",
    "error-reporting",
    "debugging",
    "debug",
    "devtools",
    "developer-tools",
    "session-replay",
    "session-recording",
    "root-cause-analysis",
    "qa-testing",
    "qa-tool",
    "chrome-extension",
    "browser-extension",
    "github-issues",
    "github",
    "jira",
    "bug-reproduction",
    "reproduction-steps",
    "sentry-alternative",
    "logrocket-alternative",
    "bugsnag-alternative",
    "fullstory-alternative",
    "console-errors",
    "network-errors",
    "frontend-debugging",
    "react",
    "nextjs",
    "vue",
    "angular",
    "typescript",
    "javascript"
  ],
  "author": {
    "name": "Prashant Singh Mangat",
    "url": "https://github.com/prashantsinghmangat"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prashantsinghmangat/TraceBug-ai.git"
  },
  "homepage": "https://github.com/prashantsinghmangat/TraceBug-ai#readme",
  "bugs": {
    "url": "https://github.com/prashantsinghmangat/TraceBug-ai/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.57.1",
    "jsdom": "^29.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "html2canvas": "1.4.1"
  }
}
