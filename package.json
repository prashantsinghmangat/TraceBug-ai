{
  "name": "tracebug-sdk",
  "version": "1.1.1",
  "description": "Zero-backend, browser-only SDK that records user sessions and generates bug reproduction steps. Data stays in localStorage.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:all": "tsup && echo [OK] npm package: dist/ && echo [OK] Chrome extension: tracebug-extension/tracebug-sdk.js",
    "build:example": "tsup && cd example-app && npm install && echo [OK] Example app updated",
    "dev": "tsup --watch",
    "prepare": "tsup"
  },
  "keywords": [
    "bug",
    "tracking",
    "session-replay",
    "error-reporting",
    "developer-tools"
  ],
  "author": {
    "name": "Prashant Singh Mangat",
    "url": "https://github.com/prashantsinghmangat"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prashantsinghmangat/TraceBug-ai.git"
  },
  "homepage": "https://github.com/prashantsinghmangat/TraceBug-ai#readme",
  "bugs": {
    "url": "https://github.com/prashantsinghmangat/TraceBug-ai/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.3.3"
  }
}
